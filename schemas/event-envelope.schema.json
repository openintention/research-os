{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-os.local/schemas/event-envelope.schema.json",
  "title": "EventEnvelope",
  "type": "object",
  "required": [
    "kind",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "workspace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "aggregate_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "aggregate_kind": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "payload": {
      "type": "object"
    },
    "tags": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}