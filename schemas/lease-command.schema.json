{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-os.local/schemas/lease-command.schema.json",
  "title": "LeaseCommand",
  "type": "object",
  "required": [
    "command_schema",
    "command_version",
    "action",
    "request_id",
    "node_id"
  ],
  "properties": {
    "command_schema": {
      "const": "openintention-lease-command-v1"
    },
    "command_version": {
      "type": "integer",
      "const": 1
    },
    "action": {
      "enum": [
        "acquire",
        "renew",
        "release",
        "fail",
        "complete",
        "heartbeat"
      ]
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string",
      "pattern": "^node_[a-z0-9]{16,64}$"
    },
    "lease_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "planner_fingerprint": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "ttl_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "participant_role": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "contributor",
        "verifier",
        null
      ]
    },
    "work_item_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "reproduce_claim",
        "contradict_claim",
        "adopt_snapshot",
        "compose_frontier",
        "explore_effort",
        "publish_summary",
        null
      ]
    },
    "subject_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "claim",
        "snapshot",
        "effort",
        "frontier",
        "summary",
        null
      ]
    },
    "subject_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "effort_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "objective": {
      "type": [
        "string",
        "null"
      ]
    },
    "platform": {
      "type": [
        "string",
        "null"
      ]
    },
    "budget_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "workspace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "observed_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "observed_claim_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "failure_reason": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "const": "acquire"
          }
        }
      },
      "then": {
        "required": [
          "planner_fingerprint",
          "ttl_seconds",
          "participant_role",
          "work_item_type",
          "subject_type",
          "subject_id"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "renew"
          }
        }
      },
      "then": {
        "required": [
          "lease_id",
          "ttl_seconds"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "enum": [
              "release",
              "fail",
              "complete",
              "heartbeat"
            ]
          }
        }
      },
      "then": {
        "required": [
          "lease_id"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "fail"
          }
        }
      },
      "then": {
        "required": [
          "failure_reason"
        ]
      }
    }
  ],
  "additionalProperties": false
}
