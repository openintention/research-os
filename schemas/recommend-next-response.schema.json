{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-os.local/schemas/recommend-next-response.schema.json",
  "title": "RecommendNextResponse",
  "type": "object",
  "required": [
    "recommendations"
  ],
  "properties": {
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action",
          "priority",
          "reason",
          "inputs"
        ],
        "properties": {
          "action": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "reason": {
            "type": "string"
          },
          "inputs": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}